{
  "manifest_version": 3,
  "name": "HomeTube Cookie Export",
  "version": "0.1.0",
  "description": "Export the active site's cookies for HomeTube.",
  "permissions": ["cookies", "tabs", "activeTab"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
